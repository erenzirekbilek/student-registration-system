    <changeSet id="002-insert-classes" author="liquibase">
        <preConditions onFail="MARK_RAN">
            <not>
                <rowCount tableName="classes">
                    <where>id = 1</where>
                </rowCount>
            </not>
        </preConditions>
        <insert tableName="classes">
            <column name="name">Class 10-A</column>
            <column name="department">Science</column>
            <column name="section">A</column>
            <column name="year">2024</column>
        </insert>
        <insert tableName="classes">
            <column name="name">Class 10-B</column>
