<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.0.xsd">

    <changeSet id="003-create-admin-table" author="liquibase">
        <preConditions onFail="HALT">
            <not>
                <tableExists tableName="admins"/>
            </not>
        </preConditions>
        <createTable tableName="admins">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true"/>
            </column>
            <column name="name" type="VARCHAR(255)" nullable="false"/>
            <column name="email" type="VARCHAR(255)" nullable="false">
                <constraints unique="true"/>
            </column>
            <column name="password" type="VARCHAR(255)" nullable="false"/>
            <column name="phone" type="VARCHAR(50)"/>
            <column name="created_at" type="TIMESTAMP"/>
        </createTable>
    </changeSet>

    <changeSet id="003-insert-admin" author="liquibase">
        <insert tableName="admins">
            <column name="name">System Admin</column>
            <column name="email">admin@school.com</column>
            <column name="password">$2a$10$N9qo8uLOkgx1z6f6F5w7Fe7jK5x5x5x5x5x5x5x5x5x5x5x5x5x</column>
            <column name="phone">+1234567890</column>
        </insert>
    </changeSet>

    <changeSet id="003-create-attendance-table" author="liquibase">
        <preConditions onFail="HALT">
            <not>
                <tableExists tableName="attendance"/>
            </not>
        </preConditions>
        <createTable tableName="attendance">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true"/>
            </column>
            <column name="student_id" type="BIGINT" nullable="false"/>
            <column name="course_id" type="BIGINT" nullable="false"/>
            <column name="date" type="DATE" nullable="false"/>
            <column name="status" type="VARCHAR(20)" nullable="false"/>
            <column name="notes" type="TEXT"/>
        </createTable>
    </changeSet>

</databaseChangeLog>