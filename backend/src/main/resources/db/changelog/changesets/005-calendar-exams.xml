<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.0.xsd">

    <changeSet id="005-academic-calendar-table" author="liquibase">
        <createTable tableName="academic_calendar">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" />
            </column>
            <column name="title" type="VARCHAR(255)" />
            <column name="description" type="TEXT" />
            <column name="event_type" type="VARCHAR(50)" />
            <column name="start_date" type="DATE" />
            <column name="end_date" type="DATE" />
            <column name="is_active" type="BOOLEAN" defaultValueBoolean="true" />
        </createTable>
    </changeSet>

    <changeSet id="005-exam-schedule-table" author="liquibase">
        <createTable tableName="exam_schedule">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" />
            </column>
            <column name="course_id" type="BIGINT" />
            <column name="course_name" type="VARCHAR(255)" />
            <column name="exam_date" type="DATE" />
            <column name="start_time" type="TIME" />
            <column name="end_time" type="TIME" />
            <column name="room" type="VARCHAR(50)" />
            <column name="exam_type" type="VARCHAR(50)" />
            <column name="is_active" type="BOOLEAN" defaultValueBoolean="true" />
        </createTable>
    </changeSet>

